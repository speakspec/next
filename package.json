{
  "name": "@speakspec/next",
  "version": "0.0.1",
  "description": "AIDP 0.3 publishing channel for Next.js (App Router) — exposes /.well-known/aidp.json and friends, fetches signed content + pointer payloads from SpeakSpec, receives §8.10 cache-invalidation webhooks.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/speakspec/aidp-sdk-next.git"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "speakspec": "./bin/speakspec.mjs"
  },
  "scripts": {
    "generate:version": "node scripts/generate-version.mjs",
    "prepare": "node scripts/generate-version.mjs",
    "build": "pnpm generate:version && tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "lint": "eslint .",
    "test": "pnpm generate:version && vitest run --passWithNoTests",
    "test:watch": "pnpm generate:version && vitest watch",
    "test:types": "pnpm generate:version && tsc --noEmit"
  },
  "dependencies": {
    "ofetch": "^1.4.1"
  },
  "peerDependencies": {
    "next": "^15.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
